POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=db
POSTGRES_DB=echoparse
REDIS_PASSWORD=password
POSTGRES_PORT=5432

# --- Configuración de Whisper AI ---
# Modelos permitidos: tiny, base, small, medium, large, turbo
# 'turbo' es el recomendado para español. 'base' o 'small' para desarrollo local rápido.
WHISPER_MODEL=turbo

# Idioma para la transcripción. Por defecto es "es" (español) para mayor eficiencia.
# Puedes borrar la variable o dejarla vacía para que Whisper auto-detecte el idioma.
WHISPER_LANGUAGE=es
