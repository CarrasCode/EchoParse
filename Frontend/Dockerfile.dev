FROM node:22-alpine

# Set working directory
WORKDIR /app

# Enable pnpm
RUN corepack enable pnpm

# Install dependencies first (for better caching)
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Copy project files
COPY . .

# Expose port 4200
EXPOSE 4200

# Start Angular development server, host 0.0.0.0 to be accessible outside the container
# We use --poll 2000 to ensure hot-reload works reliably with Docker volumes on some OSs
CMD ["pnpm", "exec", "ng", "serve", "--host", "0.0.0.0", "--poll", "2000"]
